{
  "$schema": "https://unpkg.com/syncpack@latest/schema.json",
  "customTypes": {
    "engines": { "path": "engines", "strategy": "versionsByName" },
    "optional": { "path": "optionalDependencies", "strategy": "versionsByName" },
    "packageManager": {
      "namePath": "devEngines.packageManager.name",
      "path": "devEngines.packageManager.version",
      "strategy": "name~version"
    },
    "runtime": {
      "namePath": "devEngines.runtime.name",
      "path": "devEngines.runtime.version",
      "strategy": "name~version"
    }
  },
  "semverGroups": [
    { "specifierTypes": ["range-complex", "unsupported", "link"], "isIgnored": true },
    { "dependencyTypes": ["local", "overrides", "pnpmOverrides", "resolutions"], "range": "" },
    { "dependencies": ["pyodide"], "range": "" },
    { "dependencyTypes": ["dev"], "range": "" },
    { "dependencyTypes": ["peer"], "range": "^" },
    { "dependencyTypes": ["prod"], "range": "^" },
    { "dependencyTypes": ["engines"], "range": ">=" },
    { "dependencyTypes": ["runtime", "packageManager"], "range": "^" }
  ],
  "versionGroups": [
    { "specifierTypes": ["range-complex", "unsupported", "link"], "isIgnored": true },
    {
      "dependencies": ["$LOCAL"],
      "dependencyTypes": ["dev", "prod", "peer", "optional"],
      "pinVersion": "workspace:*"
    },
    { "dependencyTypes": ["local"], "isIgnored": true },
    { "dependencyTypes": ["peer"], "preferVersion": "highestSemver" },
    { "dependencyTypes": ["prod"], "preferVersion": "highestSemver" },
    { "dependencyTypes": ["engines"], "preferVersion": "lowestSemver" },
    { "dependencyTypes": ["runtime", "packageManager"], "preferVersion": "highestSemver" }
  ]
}
